{
  "name": "jewish-event-times",
  "version": "1.0.0",
  "description": "Automatic tracking of Jewish event times using MyZmanim API",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "times": "npm run build && node dist/showTimes.js",
    "test": "jest",
    "test:whatsapp": "npm run build && node dist/testWhatsApp.js",
    "test:san-antonio": "npm run build && node dist/testSanAntonioWhatsApp.js",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/username/jewish-event-times.git"
  },
  "keywords": [
    "jewish",
    "zmanim",
    "prayer-times",
    "hebrew-calendar",
    "automation"
  ],
  "author": "Your Name",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.13.5",
    "dotenv": "^17.2.1",
    "fs-extra": "^11.1.1",
    "moment-timezone": "^0.5.43"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/jest": "^29.5.5",
    "@types/node": "^20.19.9",
    "@typescript-eslint/eslint-plugin": "^6.7.4",
    "@typescript-eslint/parser": "^6.7.4",
    "eslint": "^8.50.0",
    "jest": "^29.7.0",
    "prettier": "^3.0.3",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.2.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
